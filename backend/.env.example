APP_NAME=Draftly Backend
FRONTEND_ORIGIN=*
FRONTEND_URL=http://127.0.0.1:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_IMAGE_BUCKET=draftly-images

# Ollama
MODEL_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=4096
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=2048

# Search provider: tavily
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=basic

# Optional RAG evaluation settings. Current chatbot uses non-RAG by default.
RAG_ENABLED=false
RAG_DEBUG=false
RAG_PROVIDER=ollama
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBEDDING_TIMEOUT_SECONDS=8
RAG_EVALUATION_LOG_PATH=data/rag_evaluation_log.txt
RAG_TOP_K=2
RAG_CHUNK_SIZE=420
RAG_CHUNK_OVERLAP=80
RAG_SOURCE_CHAR_LIMIT=360
RAG_QUICK_TOP_K=1
RAG_MODERATE_TOP_K=2
RAG_DEEP_TOP_K=3
RAG_QUICK_CHUNK_SIZE=320
RAG_MODERATE_CHUNK_SIZE=420
RAG_DEEP_CHUNK_SIZE=520
RAG_QUICK_CHUNK_OVERLAP=40
RAG_MODERATE_CHUNK_OVERLAP=80
RAG_DEEP_CHUNK_OVERLAP=100
RAG_QUICK_SOURCE_CHAR_LIMIT=260
RAG_MODERATE_SOURCE_CHAR_LIMIT=360
RAG_DEEP_SOURCE_CHAR_LIMIT=520

# Web research limits
WEB_SEARCH_MAX_RESULTS=5
WEB_FETCH_MAX_SOURCES=3
WEB_EXTRACT_CHAR_LIMIT=4000
WEB_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Chat memory
CHAT_RECENT_MESSAGES_LIMIT=10

# Agent timeouts
AGENT_PLAN_TIMEOUT_SECONDS=25
AGENT_SEARCH_QUERY_TIMEOUT_SECONDS=15
AGENT_SEARCH_TIMEOUT_SECONDS=25
AGENT_FETCH_TIMEOUT_SECONDS=20
AGENT_SOURCE_CONTEXT_TIMEOUT_SECONDS=25
AGENT_RESPONSE_CHUNK_TIMEOUT_SECONDS=30
AGENT_CONVERSATION_SUMMARY_TIMEOUT_SECONDS=20

# Image generation
IMAGE_GENERATION_PROVIDER=gemini
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_ASPECT_RATIO=16:9
GEMINI_IMAGE_SIZE=1K
IMAGE_GENERATION_TIMEOUT_SECONDS=60
IMAGE_STORAGE_TIMEOUT_SECONDS=30

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=https://your-ngrok-domain.ngrok-free.dev/api/linkedin/callback
LINKEDIN_SCOPE=openid profile email w_member_social
LINKEDIN_API_VERSION=202605
LINKEDIN_POST_CHAR_LIMIT=3000
LINKEDIN_ARTICLE_PREVIEW_ENABLED=false
